---
import SuiteResultsPage from "../../../../components/llm-tests/SuiteResultsPage.astro";
import resultsYaml from "../../../../data/llm-tests/simple-tama-agentic-workflow-q1-2026/mistral-small-4/results.yml?raw";

export const prerender = true;

const site = Astro.site ?? new URL("https://upmaru.com");
const pageImage = new URL(
  "/llm-tests/simple-tama-agentic-workflow-q1-2026/mistral-small-4.png",
  site,
).toString();
---

<SuiteResultsPage
  pageTitle="Mistral Small 4 | Simple Tama Agentic Workflow - Q1 2026 | Upmaru"
  pageDescription="Mistral Small 4 results for the Simple Tama Agentic Workflow Q1 2026 test run."
  pageImage={pageImage}
  backHref="/llm-tests/simple-tama-agentic-workflow-q1-2026"
  fallbackSuiteName="Mistral Small 4"
  resultsYaml={resultsYaml}
  summaryText="Output and timing analysis for the Mistral Small 4 suite in the agentic workflow."
/>
