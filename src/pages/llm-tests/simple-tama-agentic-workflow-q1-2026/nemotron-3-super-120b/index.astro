---
import SuiteResultsPage from "../../../../components/llm-tests/SuiteResultsPage.astro";
import resultsYaml from "../../../../data/llm-tests/simple-tama-agentic-workflow-q1-2026/nemotron-3-super-120b/results.yml?raw";

export const prerender = true;

const site = Astro.site ?? new URL("https://upmaru.com");
const pageImage = new URL(
  "/llm-tests/simple-tama-agentic-workflow-q1-2026/nemotron-3-super-120b.png",
  site,
).toString();
---

<SuiteResultsPage
  pageTitle="Nemotron 3 Super 120b | Simple Tama Agentic Workflow - Q1 2026 | Upmaru"
  pageDescription="Nemotron 3 Super 120b results for the Simple Tama Agentic Workflow Q1 2026 test run."
  pageImage={pageImage}
  backHref="/llm-tests/simple-tama-agentic-workflow-q1-2026"
  fallbackSuiteName="Nemotron 3 Super 120b"
  resultsYaml={resultsYaml}
  summaryText="Output and timing analysis for the Nemotron 3 Super 120b suite in the agentic workflow."
/>
